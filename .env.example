# =============================================================================
# myskillora — Environment Variables
# Copy this file to .env.local and fill in all values before running locally.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# Get these from: https://app.supabase.com → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-side only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Razorpay
# Get these from: https://dashboard.razorpay.com → Settings → API Keys
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Safe to expose — used in frontend checkout widget
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# -----------------------------------------------------------------------------
# Cloudinary
# Get these from: https://cloudinary.com/console → Dashboard
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# -----------------------------------------------------------------------------
# Resend (Transactional Email)
# Get from: https://resend.com → API Keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=
# Must be a verified sender domain in Resend (e.g. noreply@myskillora.com)
RESEND_FROM_EMAIL=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=myskillora

# -----------------------------------------------------------------------------
# Admin
# -----------------------------------------------------------------------------
# Email address that will be granted admin role on first signup
ADMIN_EMAIL=
