{
  "name": "myskillora",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky",
    "db:migrate": "echo 'Run supabase/migrations/001_initial_schema.sql in Supabase Dashboard > SQL Editor'",
    "db:seed": "echo 'Run supabase/seed.sql in Supabase Dashboard > SQL Editor'",
    "db:seed:test": "tsx --env-file=apps/web/.env.local supabase/seed-test-data.ts",
    "db:reset:test": "tsx --env-file=apps/web/.env.local supabase/reset-test-data.ts"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@myskillora/config": "workspace:*",
    "@myskillora/tsconfig": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "tsx": "^4.22.4",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
